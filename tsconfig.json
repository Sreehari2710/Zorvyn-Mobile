{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "paths": {
      "@components/*": ["components/*"],
      "@store/*": ["store/*"],
      "@theme/*": ["theme/*"],
      "@utils/*": ["utils/*"],
      "@models/*": ["models/*"],
      "@hooks/*": ["hooks/*"],
      "@assets/*": ["assets/*"]
    },
    "types": ["jest"]
  }
}

